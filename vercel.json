{
  "outputDirectory": "public",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
